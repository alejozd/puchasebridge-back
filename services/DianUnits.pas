class function TDianUnits.GetUnitName(const ACode: string): string;
begin
  if not FUnitMap.TryGetValue(ACode, Result) then
    Result := ACode;
end;

class function TDianUnits.Exists(const ACode: string): Boolean;
begin
  Result := FUnitMap.ContainsKey(ACode);
end;

